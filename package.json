{
  "name": "code-explorer",
  "version": "0.1.0",
  "description": "面向 Claude Code 的代码仓库学习工作流工具",
  "type": "module",
  "bin": {
    "code-explorer": "./dist/cli/main.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli/main.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "tsc --noEmit -p tsconfig.json"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.60.0",
    "@mermaid-js/parser": "^1.0.1",
    "commander": "^14.0.1",
    "fast-glob": "^3.3.3",
    "ignore": "^7.0.5",
    "p-limit": "^7.1.1",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "^0.20.8",
    "xmlbuilder2": "^3.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
